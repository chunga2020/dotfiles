set confirm
set title

set formatoptions=tcq
set textwidth=80
set wrap

set nomodeline

set autoindent
set smartindent
set tabstop=4
set shiftwidth=4
set expandtab
set updatetime=100

set number numberwidth=2
set relativenumber
set cmdheight=2

set linebreak

set hlsearch
set ignorecase
set incsearch

set history=25

set foldmethod=indent
set foldlevelstart=20

set backspace=2

" persistent statusline
set laststatus=2

" filename
set statusline=%f

" filetype
set statusline+=\ %y

" read-only
set statusline+=%r

" file format (ending type)
set statusline+=[%{&ff}]

" modified and buffer number
set statusline+=[%M%n]\ \ \ \ 

" current line and column
set statusline+=%=%l.%c\ 

" percent of file
set statusline+=\ \ \ \ %p%%\ 

syntax on
filetype indent plugin on

nnoremap Y y$

nnoremap <localleader>ev :badd ~/.vimrc<cr>:bn<cr>
nnoremap <localleader>sv :so ~/.vimrc<cr>

nnoremap <Tab> :bn<cr>
nnoremap <S-Tab> :bp<cr>

nnoremap j gj
nnoremap k gk

inoremap jj <Esc>

nnoremap p ]p
nnoremap P ]P

inoremap ( ()<Left>
inoremap { {}<Left>
inoremap [ []<Left>

nnoremap <Left> <nop>
nnoremap <Right> <nop>
nnoremap <Up> <nop>
nnoremap <Down> <nop>
inoremap <Left> <nop>
inoremap <Right> <nop>
inoremap <Up> <nop>
inoremap <Down> <nop>

if &term =~ "xterm"
    let &t_SI = "\<Esc>[6 q"
    let &t_SR = "\<Esc>[4 q"
    let &t_EI = "\<Esc>[2 q"
endif

nnoremap <C-H> <C-W><C-H>
nnoremap <C-J> <C-W><C-J>
nnoremap <C-K> <C-W><C-K>
nnoremap <C-L> <C-W><C-L>

function! ClearSearch()
    let @/=""
endfunction

function! CreateLilyHeader()
    call append(0, '\version "2.18.2"')
    call append(1, '\language "english"')
    call append(2, '\pointAndClickOff')
    call append(3, "")
endfunction

augroup filetype lilypond
    autocmd!
    autocmd FileType lilypond setlocal tabstop=2
    autocmd FileType lilypond setlocal shiftwidth=2
    autocmd FileType lilypond inoremap <buffer> < <><Left>
    autocmd FileType lilypond setlocal makeprg='/usr/bin/lilypond'
    autocmd BufNewFile *.ly call CreateLilyHeader()
augroup END

function! Code()
    setlocal nospell
    setlocal autoindent
    setlocal smartindent
endfunction

command -nargs=0 Code call Code()

function Prose()
    setlocal spell spelllang=en_us
    setlocal dictionary=/usr/share/dict/words
    setlocal noautoindent
    setlocal nosmartindent
    call textobj#sentence#init()
endfunction

command -nargs=0 Prose call Prose()

function! RemoveExtraSpaces()
    :%s/ \{2,}/ /gc
endfunction

autocmd VimEnter * call histdel("cmd")

if empty(glob('~/.vim/autoload/plug.vim'))
  silent !curl -fLo ~/.vim/autoload/plug.vim --create-dirs
    \ https://raw.githubusercontent.com/junegunn/vim-plug/master/plug.vim
  autocmd VimEnter * PlugInstall --sync | source $MYVIMRC
endif

call plug#begin('~/.vim/plugged')
Plug 'airblade/vim-gitgutter'
Plug 'dkarter/bullets.vim'
Plug 'godlygeek/tabular'
Plug 'kana/vim-textobj-user'
Plug 'lervag/vimtex'
Plug 'mattn/emmet-vim'
Plug 'reedes/vim-textobj-sentence'
Plug 'tpope/vim-fugitive'
Plug 'tpope/vim-repeat'
Plug 'tpope/vim-surround'
Plug 'Yggdroot/indentLine'
call plug#end()

let g:indentLine_fileTypeExclude = ['markdown', 'tex']
let g:bullets_enabled_file_types = ['markdown', 'tex', 'text', 'gitcommit']
