#!/bin/bash

# Simple wrapper to adjust and show volume in i3
# Usage:
#     adjust-volume <action>
# Actions:
#     -d -- decrease volume
#     -i -- increase volume
#     -m -- toggle muting

notif_cmd="notify-send --hint=int:transient:1 -t 700"

usage () {
    echo "adjust-volume <action>"
    echo "Actions:"
    echo "    -d -- decrease volume"
    echo "    -i -- increase volume"
    echo "    -m -- toggle muting"
}

send_vol_notif () {
    vol_level=$(pactl list sinks | grep Volume | head -n1 | cut -d':' -f3 | cut -d'/' -f2 | awk '{$1=$1; print}')
    $notif_cmd "Volume $vol_level"
}

send_mute_notif () {
    muted=$(pactl list sinks | grep Mute | awk '{print $NF}')
    msg=""
    if [[ $muted = "no" ]]; then
        msg="Volume unmuted"
    else
        msg="Volume muted"
    fi
    $notif_cmd "$msg"
}

if [[ $# -ne 1 ]]; then
    echo "Missing action."
    usage
    exit 1
fi

action=$1
case "$action" in
    "-d")
        pactl set-sink-volume 0 -5%
        send_vol_notif
        ;;
    "-i")
        vol_level=$(pactl list sinks | grep Volume | head -n1 | cut -d':' -f3 |
            cut -d'/' -f2 | cut -d'%' -f1 | awk '{$1=$1; print}')
        if [[ $vol_level -lt 100 ]]; then
            pactl set-sink-volume 0 +5%
            send_vol_notif
        else
            notify-send "Maximum volume reached"
        fi
        ;;
    "-m")
        pactl set-sink-mute 0 toggle
        send_mute_notif
        ;;
    *)
        usage
        ;;
esac
